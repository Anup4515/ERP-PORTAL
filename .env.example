# Database (Postgres)
#
# Local Postgres:
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/dev_db
#
# Managed providers (Supabase / Neon / Azure / RDS) — paste the URL they give
# you. Append ?sslmode=verify-full for production-grade cert validation, or
# ?sslmode=require for permissive (matches most managed defaults).
# DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=verify-full

# NextAuth v5
# Generate the secret with:  openssl rand -base64 32
# Both vars should hold the SAME value — NextAuth v5 reads either depending on
# code path; matching them avoids subtle JWT-verification mismatches.
AUTH_URL=http://localhost:3000
AUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_SECRET=generate-a-random-secret-here

# App
NEXT_PUBLIC_APP_NAME=WiserWits
